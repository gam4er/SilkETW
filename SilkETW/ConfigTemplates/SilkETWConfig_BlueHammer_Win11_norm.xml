<?xml version="1.0" encoding="utf-8"?>
<SilkETWConfig>

  <!--
    BlueHammer Windows 11 profile.

    Goal:
      - Keep Object Manager handle lifecycle events from System Object Provider.
      - Keep key Kernel FileIo events needed for file/symlink correlation.
      - Run both collectors together into one NDJSON file.

    Notes:
      - On Windows 11+ the SystemProvider collector uses EnableTraceEx2.
      - On Windows 8/10 legacy fallback uses TraceSetInformation.
      - EventId values are shared across classes in MSNT_SystemTrace;
        correlate with EventName/OpcodeName, not EventId alone.
  -->

  <OutputPath>./Logs/object_file_symlink_BlueHammer_Win11.ndjson</OutputPath>

  <!--
    Kernel collector (File I/O + path/symlink signals).

    100665088 =
      EVENT_TRACE_FLAG_FILE_IO      (0x02000000)
    + EVENT_TRACE_FLAG_FILE_IO_INIT (0x04000000)
    + EVENT_TRACE_FLAG_DISK_FILE_IO (0x00000200)
    + EVENT_TRACE_FLAG_DISK_IO_INIT (0x00000400)
    + EVENT_TRACE_FLAG_DISK_IO      (0x00000100)
    = 100665089
    + EVENT_TRACE_FLAG_PROCESS (0x00000001)

    EventIdFilter focus (classic MSNT_SystemTrace events):
      64 = FileIo/Create
      69 = FileIo/SetInfo
      71 = FileIo/Rename
      75 = FileIo/FSControl
      79 = FileIo/DeletePath
      80 = FileIo/RenamePath
      81 = FileIo/SetLinkPath (important for symlink tracking)

    Optional: <EnableStackTracing>true</EnableStackTracing>
      Enables kernel call-stack capture for Process/Start, Process/End, Thread/Start,
      Image/Load and FileIO/Create events via TraceSetInformation(TraceStackTracingInfo).
      Stack-walk records appear as separate NDJSON entries with Stack1…StackN addresses.
  -->
  <ETWCollector>
    <Guid>f9beff90-c9ad-4f39-b4fc-49be905f8d35</Guid>
    <CollectorType>Kernel</CollectorType>
    <KernelKeywords>100665088</KernelKeywords>
    <!-- EventIdFilter values are shared across classes in MSNT_SystemTrace; correlate with EventName/OpcodeName, not EventId alone. 
    <EventIdFilter>0,32,64,66,67,68,69,71,74,75,76,79,80,81</EventIdFilter>
    -->
    <EventIdFilter>0,1,2,3,4,32,33,35,36,37,38,39,40,48,49,50,51,64,69,70,71,74,75,79,80,81</EventIdFilter>
    <!-- <EnableStackTracing>true</EnableStackTracing> -->
  </ETWCollector>

  <!--
    Microsoft-Windows-Kernel-File (manifest-based User collector).
    GUID: {edd08927-9cc4-4e65-b970-c2560fb5c289}
    Ref: ConfigTemplates\Microsoft-Windows-Kernel-File_manifest.xml

    Covers the same file operations as the Kernel collector above but via the modern
    manifest-based ETW path — richer structured payload (FilePath field in templates),
    no EventId aliasing issues, and compatible with ETW decoders without PDB symbols.

    Why both collectors?
      Kernel collector   → classic MSNT_SystemTrace events, lower overhead for bulk I/O.
      This collector     → modern events; has FilePath in DeletePathArgs_V1 / SetLinkPath_V1
                           templates, giving the target path for rename/hardlink/FSCTL directly.

    UserKeywords breakdown:
      KERNEL_FILE_KEYWORD_FILEIO              (0x0020) → events 23 (FSCTL), 29 (Rename29)
      KERNEL_FILE_KEYWORD_RENAME_SETLINK_PATH (0x0800) → events 27 (RenamePath), 28 (SetLinkPath)
      ────────────────────────────────────────────────
      0x0820 = combined mask

    EventIdFilter:
      23 = FSCTL        — NTFS reparse point / symlink / junction / mount point creation
                          via FSCTL_SET_REPARSE_POINT
      27 = RenamePath   — FileRenameInformation (path rename with full target path)
      28 = SetLinkPath  — FileLinkInformation   (NTFS hard link creation with target path)
      29 = Rename29     — FileRenameInformation variant (KERNEL_FILE_KEYWORD_FILEIO path)
  -->
  <ETWCollector>
    <Guid>b3f7c2a1-8d4e-4f92-a6b5-0c1e3d7f9a8b</Guid>
    <CollectorType>User</CollectorType>
    <ProviderName>edd08927-9cc4-4e65-b970-c2560fb5c289</ProviderName>
    <UserTraceEventLevel>Informational</UserTraceEventLevel>
    <UserKeywords>0x18F0</UserKeywords>
    <!--
    <EventIdFilter>23,27,28,29</EventIdFilter>
    -->
  </ETWCollector>


  <!-- 
    Custom provider for symlink tracking events from the kernel (manifest-based User collector).
    GUID: {e02a841c-75a3-4fa7-afc8-ae09cf9b7f23}

    This is an optional extra collector for symlink tracking, which can be used together with
    the Kernel and Microsoft-Windows-Kernel-File collectors above for richer symlink-related
    events. It is not strictly necessary if the Microsoft-Windows-Kernel-File provider is enabled,
    since that provider's FilePath field in the RenamePath and SetLinkPath templates already gives
    the target path for rename/hardlink/FSCTL operations.

    The custom provider gives additional events with the source path in a FilePath field, which
    can be useful for correlating with file delete events from the Kernel provider that only have
    the target path. The custom provider's events are triggered by a WPP tracepoint in the kernel
    that fires on relevant symlink-related operations, so it may have different coverage and overhead
    characteristics compared to the Microsoft-Windows-Kernel-File provider.
  -->


  <ETWCollector>
    <Guid>84c96ec7-7f3c-4307-9da0-9e3b4610c77a</Guid>
    <CollectorType>User</CollectorType>
    <ProviderName>e02a841c-75a3-4fa7-afc8-ae09cf9b7f23</ProviderName>
    <UserTraceEventLevel>Informational</UserTraceEventLevel>
    <!--
    <UserKeywords>0x18F0</UserKeywords>    
    <EventIdFilter>23,27,28,29</EventIdFilter>
    -->
  </ETWCollector>


  <!--
    Object Manager collector (System Object Provider).

    Also enables System Process and System Lock providers in the same collector.
    Each provider can now specify its own UserKeywords and event filters.

    Win11+:
      Per-provider UserKeywords are applied via EnableTraceEx2.

    Legacy fallback:
      EnableFlags 0x80000040 = PERF_OB_HANDLE.
      InformationClass 4 = TraceSystemTraceEnableFlagsInfo.
      Per-provider UserKeywords are ignored on legacy path.
  -->
  <ETWCollector>
    <Guid>52f35daf-169f-4bbc-b3c3-654ee6150418</Guid>
    <CollectorType>SystemProvider</CollectorType>
    <SystemProviderGuids>
      <!-- System Object Provider: focus on handle lifecycle stream.
           SYSTEM_OBJECT_KW_HANDLE (0x1) — create/close/duplicate only. -->
      <Provider>
        <Guid>febd7460-3d1d-47eb-af49-c9eeb1e146f2</Guid>
        <UserKeywords>0x1</UserKeywords>
      </Provider>

      <!-- System Process Provider: process/thread/image lifetime -->
      <Provider>
        <Guid>151f55dc-467d-471f-83b5-5f889d46ff66</Guid>
        <UserKeywords>0xffffffffffffffff</UserKeywords>
      </Provider>

      <!-- System Lock Provider: lock and spinlock categories -->
      <Provider>
        <Guid>721ddfd3-dacc-4e1e-b26a-a2cb31d4705a</Guid>
        <UserKeywords>0xffffffffffffffff</UserKeywords>
      </Provider>

      <!-- System IO Provider -->
      <Provider>
        <Guid>3d5c43e3-0f1c-4202-b817-174c0070dc79</Guid>
        <UserKeywords>0xffffffffffffffff</UserKeywords>
      </Provider>

      <!-- System IO Filter Provider -->
      <Provider>
        <Guid>fbd09363-9e22-4661-b8bf-e7a34b535b8c</Guid>
        <UserKeywords>0xffffffffffffffff</UserKeywords>
      </Provider>

      <!-- System Provider 
      <Provider>
        <Guid>????????-????-????-????-????????????</Guid>
        <UserKeywords>0xffffffffffffffff</UserKeywords>
      </Provider>
      -->

    </SystemProviderGuids>
	<!--
	EnableFlags: legacy Win8/10 path only; ignored on Win11+ (EnableTraceEx2 per-provider path).
	Composed for the five providers above:

	  0x80000040 = PERF_OB_HANDLE              — System Object Provider  (handle lifecycle)
	  0x00000001 = EVENT_TRACE_FLAG_PROCESS    — System Process Provider (process start/end)
	  0x00000002 = EVENT_TRACE_FLAG_THREAD     — System Process Provider (thread start/end)
	  0x00000004 = EVENT_TRACE_FLAG_IMAGE_LOAD — System Process Provider (image load)
	  0x00000100 = EVENT_TRACE_FLAG_DISK_IO    — System IO Provider
	  0x00000200 = EVENT_TRACE_FLAG_DISK_FILE_IO        — System IO Provider
	  0x00000400 = EVENT_TRACE_FLAG_DISK_IO_INIT        — System IO Provider
	  0x00010000 = EVENT_TRACE_FLAG_NETWORK_TCPIP       — System IO Provider
	  0x00200000 = EVENT_TRACE_FLAG_SPLIT_IO            — System IO Provider
	  0x00800000 = EVENT_TRACE_FLAG_DRIVER              — System IO Provider
	  0x02000000 = EVENT_TRACE_FLAG_FILE_IO             — System IO Provider
	  0x04000000 = EVENT_TRACE_FLAG_FILE_IO_INIT        — System IO Provider
	  ─────────────────────────────────────────────────────────────────────────
	  0x86A10747 = combined bitmask

	System Lock Provider and System IO Filter Provider have no direct EVENT_TRACE_FLAG
	mappings (their flags are in the PERF_* group only; covered on Win11+ via EnableTraceEx2).
	Ref: https://learn.microsoft.com/en-us/windows/win32/etw/obtrace
	Ref: TRACE_QUERY_INFO_CLASS enum, evntrace.h
  -->
  <EnableFlags>0x86A10747</EnableFlags>
	<InformationClass>4</InformationClass>
  <UserTraceEventLevel>Verbose</UserTraceEventLevel>
  <UserKeywords>0xffffffffffffffff</UserKeywords>
  </ETWCollector>

</SilkETWConfig>