<?xml version="1.0" encoding="utf-8"?>
<SilkETWConfig>

  <!--
    Object Manager tracing profile.

    Captures kernel handle create/close/duplicate events using the SystemProvider
    collector type which automatically selects the appropriate ETW path:

      Windows 11+ (build >= 22000):
        Modern path  system-logger-mode session + EnableTraceEx2 for
        System Object Provider {febd7460-3d1d-47eb-af49-c9eeb1e146f2}.
        Ref: https://learn.microsoft.com/en-us/windows/win32/etw/system-providers

      Windows 8 / 10 / Server 2012+:
        Legacy fallback  system-logger-mode session + TraceSetInformation
        with PERF_OB_HANDLE (0x80000040) via TraceSystemTraceEnableFlagsInfo.
        Ref: https://learn.microsoft.com/en-us/windows/win32/etw/obtrace

      Below Windows 8:
        Not supported  collector will fail-closed with an error message.

    EventIdFilter values (ObTrace event IDs):
      32  = CreateHandle
      33  = CloseHandle
      34  = DuplicateHandle
      36  = TypeDCStart   (type run-down start)
      37  = TypeDCEnd     (type run-down end)
      38  = HandleDCStart (handle run-down start)
      39  = HandleDCEnd   (handle run-down end)

    Remove <EventIdFilter> to capture all Object Manager events.
    Combine with the Kernel collector below to correlate file I/O with handle lifecycle.
  -->

  <OutputPath>./Logs/object_BlueHammer.ndjson</OutputPath>

  <!-- 
  Kernel file I/O collector (optional  remove if not needed).
  100665088 = 
      EVENT_TRACE_FLAG_FILE_IO (33554432) + 
      EVENT_TRACE_FLAG_FILE_IO_INIT (67108864) + 
      EVENT_TRACE_FLAG_DISK_FILE_IO (512) + 
      EVENT_TRACE_FLAG_DISK_IO_INIT (1024) +
      EVENT_TRACE_FLAG_DISK_IO (256) +

      
  "EVENT_TRACE_FLAG_PROCESS"      	    "0x00000001"
  "EVENT_TRACE_FLAG_THREAD"	            "0x00000002"
  "EVENT_TRACE_FLAG_IMAGE_LOAD"	        "0x00000004"
  "EVENT_TRACE_FLAG_PROCESS_COUNTERS"	  "0x00000008"
  "EVENT_TRACE_FLAG_CSWITCH"	          "0x00000010"
  "EVENT_TRACE_FLAG_DPC"	              "0x00000020"
  "EVENT_TRACE_FLAG_INTERRUPT"	        "0x00000040"
  "EVENT_TRACE_FLAG_SYSTEMCALL"	        "0x00000080"
  "EVENT_TRACE_FLAG_DISK_IO"	          "0x00000100"
  "EVENT_TRACE_FLAG_DISK_FILE_IO"	      "0x00000200"
  "EVENT_TRACE_FLAG_DISK_IO_INIT"	      "0x00000400"
  "EVENT_TRACE_FLAG_DISPATCHER"	        "0x00000800"
  "EVENT_TRACE_FLAG_MEMORY_PAGE_FAULTS"	"0x00001000"
  "EVENT_TRACE_FLAG_MEMORY_HARD_FAULTS"	"0x00002000"
  "EVENT_TRACE_FLAG_VIRTUAL_ALLOC"	    "0x00004000"
  "EVENT_TRACE_FLAG_NETWORK_TCPIP"	    "0x00010000"
  "EVENT_TRACE_FLAG_REGISTRY"	          "0x00020000"
  "EVENT_TRACE_FLAG_ALPC"	              "0x00100000"
  "EVENT_TRACE_FLAG_SPLIT_IO"	          "0x00200000"
  "EVENT_TRACE_FLAG_DRIVER"	            "0x00800000"
  "EVENT_TRACE_FLAG_PROFILE"	          "0x01000000"
  "EVENT_TRACE_FLAG_FILE_IO"	          "0x02000000"
  "EVENT_TRACE_FLAG_FILE_IO_INIT"	      "0x04000000"

       
  -->
  <ETWCollector>
    <Guid>c6f6f37a-2b9b-4d4a-b3d5-2f9a21d5b6d3</Guid>
    <CollectorType>Kernel</CollectorType>
    <KernelKeywords>100665088</KernelKeywords>
    <!-- 
    <EventIdFilter>64, 35, 32, 79, 72, 81</EventIdFilter>
    -->
  </ETWCollector>

  <!-- Object Manager collector.
       CollectorType = SystemProvider selects modern or legacy path automatically. -->
  <ETWCollector>
    <Guid>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Guid>
    <CollectorType>SystemProvider</CollectorType>
    <!--
      One or more System Provider GUIDs to enable.
      Win11+:   each GUID is passed to EnableTraceEx2 (modern path).
      Win8/10:  EnableFlags bitmask is used via TraceSetInformation (legacy path).
      Ref: https://learn.microsoft.com/en-us/windows/win32/etw/system-providers
    -->
    <SystemProviderGuids>
      <!-- System Object Provider: handle create/close/duplicate events -->
      <ProviderGuid>febd7460-3d1d-47eb-af49-c9eeb1e146f2</ProviderGuid>
    </SystemProviderGuids>
    <!--
      EnableFlags: ULONG bitmask for TraceSetInformation on the legacy Win8/10 path.
      0x80000040 = PERF_OB_HANDLE — enables Object Manager handle tracing (ObTrace).
      Ref: https://learn.microsoft.com/en-us/windows/win32/etw/obtrace
      Ignored on Win11+ (EnableTraceEx2 path uses UserKeywords instead).
    -->
    <EnableFlags>0x80000040</EnableFlags>
    <!--
      InformationClass: TRACE_INFO_CLASS value for TraceSetInformation.
      4 = TraceSystemTraceEnableFlagsInfo (default, maps EnableFlags to system trace flags).
      Ref: TRACE_QUERY_INFO_CLASS enum, evntrace.h
    -->
    <InformationClass>4</InformationClass>
    <UserTraceEventLevel>Verbose</UserTraceEventLevel>
    <UserKeywords>0xffffffffffffffff</UserKeywords>
    <!-- 
    <EventIdFilter>32,33,34,36,37,38,39</EventIdFilter>
    -->
  </ETWCollector>

  <!-- "Microsoft-Windows-VolumeSnapshot-Driver" -->
  <ETWCollector>
    <Guid>6d4df908-4fd8-48db-8ff3-0db02d9cb8ee</Guid>
    <CollectorType>User</CollectorType>
    <ProviderName>67fe2216-727a-40cb-94b2-c02211edb34a</ProviderName>
    <UserTraceEventLevel>Verbose</UserTraceEventLevel>
    <UserKeywords>0xffffffffffffffff</UserKeywords>
  </ETWCollector>

</SilkETWConfig>
